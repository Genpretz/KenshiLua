enum itemType { LUA_SCRIPT = 322 }

[LUA_SCRIPT]
file: 	"Lua script|*.lua" "run the following .lua script when the dialogue line occurs."

[DIALOGUE,DIALOGUE_LINE,WORD_SWAPS]
run lua script: LUA_SCRIPT "Attach a Lua script to this dialogue."
